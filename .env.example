# =============================================================================
# Local Development .env
# Combines all variables needed to run coordinator, worker, and POW service
# locally. See service-specific env files in deployment/env/ for production.
# =============================================================================

# ─── Common ────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
LOG_FORMAT=human               # "human" (ANSI colored) or "json" (single-line JSON); JSON_LOGGING=true is legacy alias for LOG_FORMAT=json
TARGET_LOGIN_URL=https://login.account.rakuten.com/sso/authorize?client_id=rakuten_ichiba_top_web&service_id=s245&response_type=code&scope=openid&redirect_uri=https%3A%2F%2Fwww.rakuten.co.jp%2F
TIMEOUT_MS=60000
REDIS_URL=redis://localhost:6379
REDIS_COMMAND_TIMEOUT=60000

# ─── Coordinator (REQUIRED: TELEGRAM_BOT_TOKEN) ──────────────────────────────
# The coordinator cannot start without these:
TELEGRAM_BOT_TOKEN=replace-me          # REQUIRED — bot will fail to start without this
TARGET_LOGIN_URL=<see above>            # REQUIRED — also listed in Common

# Optional coordinator / Telegram config
FORWARD_CHANNEL_ID=                    # Telegram channel for VALID credential forwards
ALLOWED_USER_IDS=                      # Comma-separated Telegram user IDs (empty = allow all)
METRICS_PORT=9090
METRICS_HOST=0.0.0.0
BATCH_CONCURRENCY=1
BATCH_MAX_RETRIES=2
BATCH_DELAY_MS=50
BATCH_HUMAN_DELAY_MS=0
PROXY_SERVER=
PROXY_POOL=
PROCESSED_TTL_MS=2592000000           # 30 days
FORWARD_TTL_MS=2592000000             # 30 days

# ─── Worker ────────────────────────────────────────────────────────────────────
WORKER_ID=
WORKER_CONCURRENCY=3
WORKER_TASK_TIMEOUT=120000
WORKER_HEARTBEAT_INTERVAL=10000
WORKER_QUEUE_TIMEOUT=30000
WORKER_HTTP_PORT=3010                  # Optional HTTP status endpoint
POW_SERVICE_URL=http://localhost:3001
POW_CLIENT_TIMEOUT=25000
PROCESSED_TTL_MS=2592000000           # 30 days

# ─── POW Service ───────────────────────────────────────────────────────────────
PORT=3001
POW_NUM_WORKERS=
POW_TASK_TIMEOUT=30000
POW_CLIENT_TIMEOUT=25000              # Client-side timeout (used by worker/coordinator)

# ─── Optional Debug / Instrumentation ──────────────────────────────────────────
AGENT_DEBUG_INGEST_URL=                  # Optional: pipe debug HTTP flow data here
# POW_SKIP_CONNECTION_TEST=1           # Skip POW service connectivity test on startup
                                       # (set by test:flow to avoid ~42s timeout when POW is unreachable)

# ─── Local Full-Flow Test (npm run test:flow) ─────────────────────────────────
# Used by npm run test:flow to validate one complete credential-check flow locally.
# This test runs coordinator/worker/checker logic in-process where practical.
# PoW/CRES is computed directly using internal PoW modules instead of requiring
# a separately running pow-service instance.
TEST_EMAIL=
TEST_PASSWORD=
