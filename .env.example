# =============================================================================
# Local Development .env
# Combines all variables needed to run coordinator, worker, and POW service
# locally. See service-specific env files in deployment/env/ for production.
# =============================================================================

# --- Common ---
NODE_ENV=development
LOG_LEVEL=debug
TARGET_LOGIN_URL=https://login.account.rakuten.com/sso/authorize?client_id=rakuten_ichiba_top_web&service_id=s245&response_type=code&scope=openid&redirect_uri=https%3A%2F%2Fwww.rakuten.co.jp%2F
TIMEOUT_MS=60000
REDIS_URL=redis://localhost:6379
REDIS_COMMAND_TIMEOUT=60000

# --- Coordinator (Telegram bot) ---
TELEGRAM_BOT_TOKEN=replace-me
FORWARD_CHANNEL_ID=
ALLOWED_USER_IDS=
METRICS_PORT=9090
BATCH_CONCURRENCY=1
BATCH_MAX_RETRIES=2
BATCH_DELAY_MS=50
BATCH_HUMAN_DELAY_MS=0
PROXY_SERVER=
PROXY_POOL=
PROCESSED_TTL_MS=2592000000
FORWARD_TTL_MS=2592000000

# --- Worker ---
WORKER_ID=
WORKER_CONCURRENCY=3
WORKER_TASK_TIMEOUT=120000
WORKER_HEARTBEAT_INTERVAL=10000
WORKER_QUEUE_TIMEOUT=30000
POW_SERVICE_URL=http://localhost:3001

# --- POW Service ---
PORT=3001
POW_NUM_WORKERS=
POW_TASK_TIMEOUT=30000

# --- Local Full-Flow Test (npm run test:flow) ---
# Used by npm run test:flow to validate one complete credential-check flow locally.
# This test runs coordinator/worker/checker logic in-process where practical.
# PoW/CRES is computed directly using internal PoW modules instead of requiring
# a separately running pow-service instance.
TEST_EMAIL=
TEST_PASSWORD=
