# Required
TELEGRAM_BOT_TOKEN=
TARGET_LOGIN_URL=

# Core runtime
NODE_ENV=production
LOG_LEVEL=info
TIMEOUT_MS=60000

# Coordinator / bot behavior
COORDINATOR_MODE=true
FORWARD_CHANNEL_ID=
ALLOWED_USER_IDS=
METRICS_PORT=9090
METRICS_HOST=0.0.0.0

# Batch settings
BATCH_CONCURRENCY=1
BATCH_MAX_RETRIES=2
BATCH_DELAY_MS=50
BATCH_HUMAN_DELAY_MS=0
PROCESSED_TTL_MS=2592000000
FORWARD_TTL_MS=2592000000

# Redis
REDIS_URL=
REDIS_COMMAND_TIMEOUT=60000
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Proxy
PROXY_SERVER=
PROXY_POOL=

# Worker
WORKER_ID=
WORKER_CONCURRENCY=3
WORKER_TASK_TIMEOUT=120000
WORKER_HEARTBEAT_INTERVAL=10000
WORKER_QUEUE_TIMEOUT=30000
WORKER_HTTP_PORT=

# POW
POW_SERVICE_MODE=false
POW_SERVICE_URL=http://localhost:3001
POW_CLIENT_TIMEOUT=25000
POW_NUM_WORKERS=
POW_TASK_TIMEOUT=30000
PORT=3001

# Optional diagnostics
AGENT_DEBUG_INGEST_URL=
TRACE_ID=
