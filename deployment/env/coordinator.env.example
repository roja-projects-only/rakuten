# =============================================================================
# Coordinator Service Environment
# =============================================================================
# Self-contained example for the coordinator. Each variable has a default if
# marked [optional]; empty values fall back to built-in defaults.
#
# REQUIRED — coordinator WILL FAIL TO START if these are missing or empty:
#   TELEGRAM_BOT_TOKEN, TARGET_LOGIN_URL, REDIS_URL
#
# NOTE: Shared vars (REDIS_URL, TARGET_LOGIN_URL, etc.) are included here so
# this file is self-contained. In production you may source a common file
# alongside this one if you prefer separation.
# =============================================================================

# ─── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=replace-me          # REQUIRED: Telegram bot token from @BotFather
TARGET_LOGIN_URL=https://login.account.rakuten.com/sso/authorize?client_id=rakuten_ichiba_top_web&service_id=s245&response_type=code&scope=openid&redirect_uri=https%3A%2F%2Fwww.rakuten.co.jp%2F
REDIS_URL=redis://localhost:6379

# ─── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
TIMEOUT_MS=60000                         # HTTP timeout for credential checks
REDIS_COMMAND_TIMEOUT=60000              # Must be > WORKER_QUEUE_TIMEOUT

# ─── Telegram (optional) ───────────────────────────────────────────────────────
FORWARD_CHANNEL_ID=                      # Channel for VALID credential forwards (numeric ID)
ALLOWED_USER_IDS=                        # Comma-separated user IDs (empty = allow all)

# ─── Metrics ───────────────────────────────────────────────────────────────────
METRICS_PORT=9090
METRICS_HOST=0.0.0.0

# ─── Batch Processing ──────────────────────────────────────────────────────────
BATCH_CONCURRENCY=1
BATCH_MAX_RETRIES=2
BATCH_DELAY_MS=50
BATCH_HUMAN_DELAY_MS=0

# ─── Proxy ─────────────────────────────────────────────────────────────────────
PROXY_SERVER=                            # Single proxy URL (legacy)
PROXY_POOL=                              # Comma-separated proxy URLs

# ─── Cache TTL ─────────────────────────────────────────────────────────────────
PROCESSED_TTL_MS=2592000000             # Dedup cache TTL (30 days)
FORWARD_TTL_MS=2592000000               # Forward tracking TTL (30 days)
