# Shared environment variables for all services
# Source this file alongside a service-specific env file

# Redis (required for coordinator and worker; optional for pow-service cache)
REDIS_URL=redis://localhost:6379

# Target login URL (required for coordinator and worker)
TARGET_LOGIN_URL=https://login.account.rakuten.com/sso/authorize?client_id=rakuten_ichiba_top_web&service_id=s245&response_type=code&scope=openid&redirect_uri=https%3A%2F%2Fwww.rakuten.co.jp%2F

# Logging
NODE_ENV=production
LOG_LEVEL=info

# HTTP timeout for credential checks (ms)
TIMEOUT_MS=60000

# Redis command timeout (ms) — must be greater than WORKER_QUEUE_TIMEOUT
REDIS_COMMAND_TIMEOUT=60000
