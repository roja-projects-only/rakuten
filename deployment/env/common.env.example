# =============================================================================
# Shared Environment Variables (Reference)
# =============================================================================
# This file documents variables shared across multiple services.
# For production deployment, each service now has a self-contained env example:
#   deployment/env/coordinator.env.example
#   deployment/env/worker.env.example
#   deployment/env/pow-service.env.example
#
# Use this file as a reference for what each shared var means.
# =============================================================================

# ─── Redis (required for coordinator and worker; optional for pow-service cache)
REDIS_URL=redis://localhost:6379

# ─── Target Login URL (required for coordinator and worker)
TARGET_LOGIN_URL=https://login.account.rakuten.com/sso/authorize?client_id=rakuten_ichiba_top_web&service_id=s245&response_type=code&scope=openid&redirect_uri=https%3A%2F%2Fwww.rakuten.co.jp%2F

# ─── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
TIMEOUT_MS=60000
REDIS_COMMAND_TIMEOUT=60000

# ─── POW Service endpoint (required for worker AND coordinator — coordinator uses POW transitively via checkCredentials)
# POW_SERVICE_URL=http://pow-service:3001
# POW_CLIENT_TIMEOUT=25000
