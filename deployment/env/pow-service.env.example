# =============================================================================
# POW Service Environment
# =============================================================================
# Self-contained example for the POW service.
#
# No strictly required vars — PORT defaults to 3001, Redis is optional.
# =============================================================================

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ─── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
REDIS_COMMAND_TIMEOUT=60000

# ─── Redis (optional — for result caching) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379         # POW cache; service runs without it if missing

# ─── Worker Pool ──────────────────────────────────────────────────────────────
POW_NUM_WORKERS=                         # CPU count auto-detected if empty
POW_TASK_TIMEOUT=30000                   # Per-computation timeout (milliseconds)
