# =============================================================================
# Worker Service Environment
# =============================================================================
# Self-contained example for the worker. Each variable has a default if
# marked [optional]; empty values fall back to built-in defaults.
#
# REQUIRED — worker WILL FAIL TO START if these are missing or empty:
#   REDIS_URL, TARGET_LOGIN_URL
#
# NOTE: Shared vars (REDIS_URL, TARGET_LOGIN_URL, etc.) are included here so
# this file is self-contained. In production you may source a common file
# alongside this one if you prefer separation.
# =============================================================================

# ─── Required ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
TARGET_LOGIN_URL=https://login.account.rakuten.com/sso/authorize?client_id=rakuten_ichiba_top_web&service_id=s245&response_type=code&scope=openid&redirect_uri=https%3A%2F%2Fwww.rakuten.co.jp%2F

# ─── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
TIMEOUT_MS=60000                         # HTTP timeout for credential checks
REDIS_COMMAND_TIMEOUT=60000              # Must be > WORKER_QUEUE_TIMEOUT

# ─── Worker Identity ───────────────────────────────────────────────────────────
WORKER_ID=                               # Unique ID (auto-generated if empty)

# ─── Concurrency / Performance ─────────────────────────────────────────────────
WORKER_CONCURRENCY=3                     # Concurrent tasks (1-50)
WORKER_TASK_TIMEOUT=120000               # Per-task timeout (milliseconds)
WORKER_HEARTBEAT_INTERVAL=10000          # Redis heartbeat interval (milliseconds)
WORKER_QUEUE_TIMEOUT=30000               # Queue poll timeout (milliseconds)
WORKER_HTTP_PORT=3010                    # Optional HTTP status endpoint

# ─── POW Service ───────────────────────────────────────────────────────────────
POW_SERVICE_URL=http://pow-service:3001  # External POW service endpoint
POW_CLIENT_TIMEOUT=25000                 # Client timeout for POW HTTP requests

# ─── Batch Processing ──────────────────────────────────────────────────────────
BATCH_MAX_RETRIES=2

# ─── Cache ─────────────────────────────────────────────────────────────────────
PROCESSED_TTL_MS=2592000000             # Dedup cache TTL (30 days)
